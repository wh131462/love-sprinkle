{
  "manifest_version": 3,
  "name": "爱心满满",
  "version": "1.0.0",
  "description": "在网页上随机飘出彩色爱心，支持弹窗控制启停",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "爱心满满"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["heart.js"]
  }]
}
